{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false, // এটি false করে দিন
    "noImplicitAny": false, // এটি যোগ করুন
    "strictNullChecks": false // এটি যোগ করুন
  }
}
